GEMINI_API_KEY=your_gemini_api_key_here
NEWS_API_KEY=your_newsapi_key_here
# Optional: cap fetched articles (default 3 for quick tests; e.g. 10 for fuller briefings)
# MAX_ARTICLES=10
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here
# Twilio outbound calling
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Public URL for FastAPI webhook (Twilio status callbacks)
# Local dev: run `ngrok http 8000` and paste the HTTPS URL here
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app
